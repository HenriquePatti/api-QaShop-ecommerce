{
  "name": "api-qashop-ecommerce",
  "version": "1.0.0",
  "description": "E-commerce REST API designed as a base for QA practice",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "test": "mocha",
    "test:report": "mocha --reporter mochawesome --reporter-options reportDir=tests-reports,reportFilename=reports,html=true,json=true,charts=true",
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "db:seed": "node prisma/seed.js",
    "db:reset": "prisma migrate reset --force"
  },
  "keywords": [
    "ecommerce",
    "qa",
    "rest-api",
    "express",
    "prisma",
    "swagger"
  ],
  "author": "Henrique Patti",
  "license": "MIT",
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "chai": "^6.2.2",
    "mocha": "^11.7.6",
    "mochawesome": "^7.1.4",
    "prisma": "^5.22.0",
    "supertest": "^7.2.2"
  }
}
